// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
    id Int @id @default(autoincrement())
    username String @unique
    email String @unique
    password String
    orders    Orders[]
    position Position[]
    balances  Balance[]
    tradeHistory TradeHistory[]
}

model Orders {
    id Int @id @default(autoincrement())
    userId    Int
    symbol    String
    type      String
    status    String
    price     Float
    quantity  Float
    tradeHistory TradeHistory[]
    createdAt DateTime @default(now())
    user      User     @relation(fields: [userId], references: [id])
}

model Balance {
  id        Int      @id @default(autoincrement())
  userId    Int
  currency  String
  amount    Float    @default(0)
  user      User     @relation(fields: [userId], references: [id])
}

model TradeHistory {
  id Int @id @default(autoincrement())
  userId Int
  orderId Int
  symbol String
  type String
  status String
  price Float
  quantity Float
  executedAt DateTime @default(now())

  user User @relation(fields:[userId] , references :[id])
  order Orders @relation(fields:[orderId] , references:[id])
}

model Position {
  id Int @id @default(autoincrement())
  userId Int
  symbol String
  type String
  entryPrice Float
  quantity Float
  user User @relation(fields:[userId],references:[id])
}

model Instrument {
    id Int @id @default(autoincrement())
    symbol String
    name String
    tickSize Float
    leverage Int
}
